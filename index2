*{margin:0;padding:0;box-sizing:border-box;}
html,body{width:100%;height:100%;overflow:hidden;}
body{font-family:'Pretendard','Noto Sans KR',sans-serif;background:#000;}

/* ── PAGES ── */
.page{position:fixed;inset:0;transition:opacity 0.6s ease;z-index:10;}
.page.hidden{opacity:0;pointer-events:none;}
.page.gone{display:none!important;}

/* ── HOME ── */
#pg-home{display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;}
.home-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(.72);}
