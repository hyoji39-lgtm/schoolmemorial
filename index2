// ══ TILE PICKER ══
let pendingEntry=null, hoveredCell=null;

function openTilePicker(){
  document.getElementById('tilePickerBg').style.backgroundImage=`url(data:image/jpeg;base64,${WALL_B64})`;
  document.getElementById('tilePicker').style.display='block';
  requestAnimationFrame(drawGrid);
}
function closeTilePicker(){
  document.getElementById('tilePicker').style.display='none';
  pendingEntry=null; hoveredCell=null;
}

function drawGrid(){
  const cv=document.getElementById('tileGrid');
  const W=cv.offsetWidth, H=cv.offsetHeight;
  cv.width=W; cv.height=H;
  const ctx=cv.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const used=getUsedCells();

  for(let r=0;r<G_ROWS;r++){
    for(let c=0;c<G_COLS;c++){
      const idx=r*G_COLS+c;
      const x=G_XS[c]/100*W, y=G_YS[r]/100*H;
      const tw=G_CW/100*W,   th=G_CH/100*H;

      if(used.has(idx)){
        // 이미 사용됨: 반투명 어둡게 + X
        ctx.fillStyle='rgba(0,0,0,0.5)';
        ctx.fillRect(x,y,tw,th);
        ctx.strokeStyle='rgba(255,60,60,0.8)';
        ctx.lineWidth=1.5;
        ctx.beginPath();
        ctx.moveTo(x+4,y+4);ctx.lineTo(x+tw-4,y+th-4);
        ctx.moveTo(x+tw-4,y+4);ctx.lineTo(x+4,y+th-4);
        ctx.stroke();
      }else if(hoveredCell===idx){
        // 호버: 금색 하이라이트
        ctx.fillStyle='rgba(212,168,75,0.55)';
        ctx.fillRect(x,y,tw,th);
        ctx.strokeStyle='rgba(212,168,75,0.95)';
        ctx.lineWidth=2.5;
        ctx.strokeRect(x+1,y+1,tw-2,th-2);
        // + 아이콘
        ctx.strokeStyle='rgba(255,255,255,0.9)';
        ctx.lineWidth=2;
        ctx.beginPath();
        ctx.moveTo(x+tw/2,y+4);ctx.lineTo(x+tw/2,y+th-4);
        ctx.moveTo(x+4,y+th/2);ctx.lineTo(x+tw-4,y+th/2);
        ctx.stroke();
      }else{
        // 선택 가능: 테두리만
        ctx.strokeStyle='rgba(212,168,75,0.4)';
        ctx.lineWidth=1;
        ctx.strokeRect(x+1,y+1,tw-2,th-2);
      }
    }
  }
}

function cellFromXY(mx,my,W,H){
  const tw=G_CW/100*W, th=G_CH/100*H;
  let col=-1,row=-1;
  for(let c=0;c<G_COLS;c++){
    const x=G_XS[c]/100*W;
    if(mx>=x&&mx<x+tw){col=c;break;}
  }
  for(let r=0;r<G_ROWS;r++){
    const y=G_YS[r]/100*H;
    if(my>=y&&my<y+th){row=r;break;}
  }
  if(col<0||row<0) return null;
  return row*G_COLS+col;
}

function placeOnCell(cell){
  if(cell===null) return;
  if(getUsedCells().has(cell)){toast('이미 다른 마음이 있는 자리예요!');return;}
  if(!pendingEntry){toast('오류: 작품 정보가 없습니다.');return;}
  // pendingEntry를 로컬 복사 후 즉시 진행 (closeTilePicker가 null로 바꾸기 전에)
  const entryToSave = Object.assign({}, pendingEntry, {cell: cell});
  closeTilePicker();
  toast('저장 중...');
  save(entryToSave).then(()=>{
    toast('📌 기억의 방에 붙었습니다!');
  }).catch(err=>{
    console.error('저장 실패:', err);
    toast('저장 중 오류가 발생했습니다');
  });
}

(()=>{
  const cv=document.getElementById('tileGrid');

  cv.addEventListener('mousemove',e=>{
    const r=cv.getBoundingClientRect();
    const cell=cellFromXY(e.clientX-r.left,e.clientY-r.top,r.width,r.height);
    if(cell!==hoveredCell){hoveredCell=cell;drawGrid();}
  });
  cv.addEventListener('mouseleave',()=>{hoveredCell=null;drawGrid();});

  cv.addEventListener('click',e=>{
    const r=cv.getBoundingClientRect();
    placeOnCell(cellFromXY(e.clientX-r.left,e.clientY-r.top,r.width,r.height));
  });
  cv.addEventListener('touchend',e=>{
    e.preventDefault();
    const t=e.changedTouches[0], r=cv.getBoundingClientRect();
    placeOnCell(cellFromXY(t.clientX-r.left,t.clientY-r.top,r.width,r.height));
  },{passive:false});

  document.getElementById('tilePickerCancel').addEventListener('click',closeTilePicker);
})();

