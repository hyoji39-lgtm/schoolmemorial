// ══ DRAW ══
const dc=document.getElementById('drawCv'),dCtx=dc.getContext('2d');
let drawing=false,lx=0,ly=0,hasDrawn=false,inkC='#1a1208',bSz=6;

function syncCanvas(){
  if(hasDrawn) return;  // 이미 그리는 중이면 리사이즈 금지 (내용 지워짐)
  const r=dc.getBoundingClientRect();
  if(r.width>0 && Math.round(r.width) !== dc.width){
    dc.width=Math.round(r.width);
    dc.height=Math.round(r.height)||155;
  }
}
function getXY(e){
  const r=dc.getBoundingClientRect();
  let cx,cy;
  if(e.touches&&e.touches.length){cx=e.touches[0].clientX;cy=e.touches[0].clientY;}
  else{cx=e.clientX;cy=e.clientY;}
  return{x:cx-r.left,y:cy-r.top};
}
function doStroke(x1,y1,x2,y2){
  dCtx.beginPath();dCtx.moveTo(x1,y1);dCtx.lineTo(x2,y2);
  dCtx.strokeStyle=inkC;dCtx.lineWidth=bSz;dCtx.lineCap='round';dCtx.lineJoin='round';dCtx.stroke();
}
dc.addEventListener('mousedown',e=>{e.preventDefault();const p=getXY(e);lx=p.x;ly=p.y;drawing=true;hasDrawn=true;});
dc.addEventListener('mousemove',e=>{e.preventDefault();if(!drawing)return;const p=getXY(e);doStroke(lx,ly,p.x,p.y);lx=p.x;ly=p.y;});
dc.addEventListener('mouseup',e=>{e.preventDefault();drawing=false;});
dc.addEventListener('mouseleave',()=>drawing=false);
dc.addEventListener('touchstart',e=>{e.preventDefault();const p=getXY(e);lx=p.x;ly=p.y;drawing=true;hasDrawn=true;},{passive:false});
dc.addEventListener('touchmove',e=>{e.preventDefault();if(!drawing)return;const p=getXY(e);doStroke(lx,ly,p.x,p.y);lx=p.x;ly=p.y;},{passive:false});
dc.addEventListener('touchend',e=>{e.preventDefault();drawing=false;},{passive:false});

function clrDraw(){dCtx.clearRect(0,0,dc.width*2,dc.height*2);hasDrawn=false;}
