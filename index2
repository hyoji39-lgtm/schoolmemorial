#notes{position:absolute;inset:0;z-index:2;overflow:hidden;pointer-events:none;}
.note{pointer-events:auto;}

/* 마음 남기기 버튼 */
.wall-cta-wrap{position:absolute;bottom:0;left:0;right:0;z-index:20;display:flex;flex-direction:column;align-items:center;padding:20px 20px 30px;background:linear-gradient(0deg,rgba(10,8,5,.9) 50%,transparent 100%);pointer-events:none;}
