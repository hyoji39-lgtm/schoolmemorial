// ══ 그리드 유틸 ══
function cellToXY(idx){
  if(idx === null || idx === undefined || isNaN(idx)) return null;
  const sc=document.getElementById('scene');
  const W=sc.offsetWidth||window.innerWidth;
  const H=sc.offsetHeight||window.innerHeight;
  const c=idx%G_COLS, r=Math.floor(idx/G_COLS);
  if(c<0||c>=G_COLS||r<0||r>=G_ROWS) return null;
  return{
    x: G_XS[c]/100*W,
    y: G_YS[r]/100*H,
    w: G_CW/100*W,
    h: G_CH/100*H
  };
}

function getUsedCells(){
  const s=new Set();
  entries.forEach(e=>{
    if(e && e.cell !== undefined && e.cell !== null && !isNaN(e.cell)) s.add(e.cell);
  });
  return s;
}

// ══ RENDER NOTES ══
function renderNotes(){
  syncEntries();
  const cont=document.getElementById('notes');
  const ewEl=document.getElementById('ew');
  if(ewEl) ewEl.classList.toggle('show', entries.length===0);
  const wcEl=document.getElementById('wc');
  if(wcEl) wcEl.textContent=entries.length+'건의 마음';
  cont.innerHTML='';
  if(!entries.length) return;

  entries.forEach(function(e,i){
    // null/undefined/불완전 데이터 방어
    if(!e || typeof e !== 'object') return;
    if(!e.content && !e.contentUrl) return;  // 내용 없는 항목 스킵
    // cell 없으면 인덱스 기반 배정
    if(e.cell === undefined || e.cell === null) {
      e.cell = ((i*3+1) % G_COLS) + (((i*5+2) % G_ROWS) * G_COLS);
    }
    const p = cellToXY(e.cell);
    if(!p) return;
    const tilt=TILTS[i%TILTS.length];

    const wrap=document.createElement('div');
    wrap.className='note';
    wrap.style.cssText=[
      'left:'+p.x+'px','top:'+p.y+'px',
      'width:'+p.w+'px','height:'+p.h+'px',
      '--r:'+tilt+'deg',
      'animation-delay:'+Math.min(i,10)*0.07+'s'
    ].join(';');

    const pin=document.createElement('div');
    pin.className='pin';

    const inner=document.createElement('div');
    inner.style.cssText='width:100%;height:100%;';

    if(e.ctype==='image'){
      const card=document.createElement('div');
      card.style.cssText='width:100%;height:100%;overflow:hidden;background:#fff;box-shadow:2px 3px 10px rgba(0,0,0,.5);';
      const img=document.createElement('img');
      img.src=e.content; img.alt='';
      img.style.cssText='width:100%;height:100%;object-fit:cover;display:block;';
      card.appendChild(img);
      inner.appendChild(card);
    }else{
      const bg=e.color&&e.color.bg?e.color.bg:'#fef08a';
      const sh=e.color&&e.color.sh?e.color.sh:'rgba(0,0,0,.4)';
      const card=document.createElement('div');
      card.style.cssText=[
        'width:100%','height:100%','box-sizing:border-box',
        'background:'+bg,
        'box-shadow:2px 3px 10px '+sh,
        'display:flex','align-items:center','justify-content:center',
        'overflow:hidden','padding:3px'
      ].join(';');
      if(e.ctype==='draw'){
        const mc=document.createElement('canvas');
        mc.width=90; mc.height=70;
        mc.style.cssText='width:100%;height:100%;display:block;';
        const img=new Image();
        img.onload=()=>mc.getContext('2d').drawImage(img,0,0,90,70);
        img.src=e.content;
        card.appendChild(mc);
      }
      inner.appendChild(card);
    }

    wrap.appendChild(pin);
    wrap.appendChild(inner);
    wrap.addEventListener('click',()=>openLb(e));
    cont.appendChild(wrap);
  });
}

