.home-content{position:relative;z-index:2;text-align:center;display:flex;flex-direction:column;align-items:center;animation:fadeUp 1.2s ease both;}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.home-title{font-size:clamp(36px,6vw,72px);font-weight:800;color:#fff;letter-spacing:-.01em;line-height:1.15;text-shadow:0 2px 28px rgba(0,0,0,.55);}
.home-line{width:60px;height:1px;background:linear-gradient(90deg,transparent,var(--gold2),transparent);margin:24px auto;}
.home-desc{color:rgba(255,255,255,.6);font-size:clamp(13px,1.6vw,16px);letter-spacing:.06em;font-weight:300;line-height:1.9;}
.enter-btn{margin-top:36px;background:none;border:1.5px solid rgba(255,255,255,.7);color:#fff;padding:15px 46px;font-size:clamp(14px,2vw,17px);font-weight:500;letter-spacing:.1em;cursor:pointer;transition:background .25s,transform .2s;}
.enter-btn:hover{background:rgba(255,255,255,.08);transform:scale(1.03);}
.enter-btn:active{transform:scale(.98);}
.btn-arrow{margin-left:10px;display:inline-block;animation:arrpulse 1.5s ease-in-out infinite;}
@keyframes arrpulse{0%,100%{transform:translateX(0)}50%{transform:translateX(5px)}}

/* ── VIDEO ── */
#pg-video{background:#000;}
#entranceVideo{width:100%;height:100%;object-fit:cover;display:block;background:#000;}
.skip-btn{position:absolute;bottom:28px;right:28px;z-index:20;background:rgba(0,0,0,.45);border:1px solid rgba(255,255,255,.3);color:rgba(255,255,255,.8);padding:9px 20px;font-size:12px;letter-spacing:.12em;cursor:pointer;backdrop-filter:blur(4px);border-radius:999px;opacity:0;animation:fadeIn .5s 1s ease both;}
