<script>
// ══ BASE64 ══
const WALL_B64  = '';
const THUMB_B64 = '';
const VIDEO_B64 = '';

// ══ 가상 그리드 (벽 이미지 기준: 12열 x 6행) ══
const G_COLS = 25;
const G_ROWS = 20;
// 각 칸의 left/top (% 단위, 화면 기준)
const G_XS = [4.0, 7.68, 11.36, 15.04, 18.72, 22.4, 26.08, 29.76, 33.44, 37.12, 40.8, 44.48, 48.16, 51.84, 55.52, 59.2, 62.88, 66.56, 70.24, 73.92, 77.6, 81.28, 84.96, 88.64, 92.32];
const G_YS = [28.0, 31.0, 34.0, 37.0, 40.0, 43.0, 46.0, 49.0, 52.0, 55.0, 58.0, 61.0, 64.0, 67.0, 70.0, 73.0, 76.0, 79.0, 82.0, 85.0];
const G_CW = 3.2384;   // 칸 가로 %
const G_CH = 2.46;     // 칸 세로 %
const TILTS = [-5,-3,-1,1,3,5,-4,4,-2,2,0,-6,6];

// ══ DATA ══
let entries = [];

// Firebase onValue가 window._entries를 채우면 여기서 동기화
function syncEntries() {
  if(window._entries) {
    entries = window._entries;
  } else {
    // Firebase 로드 전 localStorage 표시
    try {
      const cached = localStorage.getItem('bohun_v6');
      if(cached) entries = JSON.parse(cached);
    } catch(e) {}
  }
}

async function save(entry) {
  // 이미지 용량 압축 (Firebase 저장 크기 최소화)
  if(entry.content && entry.content.startsWith('data:')) {
    entry.content = await compressImage(entry.content, entry.ctype);
  }

  // fbReady 대기 (최대 5초)
  let waited = 0;
  while(!window.fbReady && waited < 5000) {
    await new Promise(r => setTimeout(r, 200));
    waited += 200;
  }

  console.log('fbReady:', window.fbReady, 'fbSave:', !!window.fbSave);

  if(window.fbReady && window.fbSave) {
    try {
      const ok = await window.fbSave(entry);
      if(!ok) {
        toast('저장 실패 — 다시 시도해주세요');
        _localFallback(entry);
      }
    } catch(err) {
      console.error('save 오류:', err);
      toast('오류: ' + err.message);
      _localFallback(entry);
    }
  } else {
    console.warn('Firebase 미연결 — 로컬 저장');
    toast('Firebase 연결 안됨 — 로컬 저장');
    _localFallback(entry);
  }
}

// 이미지 압축 (최대 400x400, 품질 0.7)
async function compressImage(dataUrl, ctype) {
  return new Promise(resolve => {
    const img = new Image();
    img.onload = () => {
      const MAX = 500;
      let w = img.width, h = img.height;
      if(w > MAX || h > MAX) {
        const ratio = Math.min(MAX/w, MAX/h);
        w = Math.round(w * ratio);
        h = Math.round(h * ratio);
      }
      const cv = document.createElement('canvas');
      cv.width = w; cv.height = h;
      const ctx = cv.getContext('2d');
      // draw 타입은 흰 배경 깔기 (투명 → jpeg 변환 시 검정 방지)
      if(ctype === 'draw') {
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, w, h);
      }
      ctx.drawImage(img, 0, 0, w, h);
      resolve(cv.toDataURL('image/jpeg', 0.8));
    };
    img.onerror = () => resolve(dataUrl);
    img.src = dataUrl;
  });
}

function _localFallback(entry) {
  try {
    const all = JSON.parse(localStorage.getItem('bohun_v6')||'[]');
    all.unshift(entry);
    localStorage.setItem('bohun_v6', JSON.stringify(all.slice(0,200)));
    entries = all;
    renderNotes();
  } catch(e) { console.warn('로컬 저장 실패', e); }
}

